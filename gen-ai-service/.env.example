DATABASE_URL=postgresql://finsocial:password@localhost:5432/finsocial_db
GEMINI_API_KEY=your_google_gemini_api_key_here
# Primary model (default: gemini-3-flash-preview)
GEMINI_MODEL=gemini-3-flash-preview
# Comma-separated fallbacks if primary fails (quota, empty response, preview outage)
GEMINI_MODEL_FALLBACKS=gemini-3.1-flash-lite
