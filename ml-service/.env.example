# Copy to .env — ml-service loads this via python-dotenv (not automatic in Python)
DATABASE_URL=postgresql://finsocial:password@localhost:5432/finsocial_db
FLASK_ENV=production

# Render 512MB instances: keep DISABLE_FINBERT=1 (default in Dockerfile). Use keyword sentiment for news.
# DISABLE_FINBERT=1

# Training label (optional — defaults: 5-day forward return > 1%)
# ML_LABEL_HORIZON_DAYS=5
# ML_LABEL_THRESHOLD=0.01
