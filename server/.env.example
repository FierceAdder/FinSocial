# ─── Required ───────────────────────────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_string
DATABASE_URL=postgresql://finsocial:password@localhost:5432/finsocial_db

# ─── Optional with defaults ─────────────────────────────────────────────
JWT_REFRESH_SECRET=replace_with_another_64_char_random_string
# macOS AirPlay Receiver often binds :5000 — use 5050 for local dev if EADDRINUSE
PORT=5050
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── Service URLs ───────────────────────────────────────────────────────
# Preferred (single string — use rediss:// for TLS)
REDIS_URL=redis://localhost:6379
# Optional legacy fallback if REDIS_URL is unset:
# REDIS_HOST=localhost
# REDIS_PORT=6379
ML_SERVICE_HOST=localhost
ML_SERVICE_PORT=5001
# Optional: full URL for split HTTPS deploy (e.g. Render). Overrides HOST+PORT when set.
# ML_SERVICE_URL=https://your-ml-service.onrender.com

GEN_AI_SERVICE_HOST=localhost
GEN_AI_SERVICE_PORT=5002
# Required on Render for FinBot / news summaries — public URL of gen-ai service (not localhost)
GEN_AI_SERVICE_URL=https://your-gen-ai.onrender.com

# ─── External APIs ──────────────────────────────────────────────────────
ALPHAVANTAGE_API_KEY=your_alpha_vantage_key_here
NEWSAPI_KEY=your_newsapi_key_here
SENDGRID_API_KEY=your_sendgrid_key_here
SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/0
