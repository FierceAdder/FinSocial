VITE_SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/0
# Dev proxy target: nginx stack on :9999, or Express only on :5000
VITE_DEV_BACKEND=http://localhost:9999
# Production (e.g. Vercel): WebSockets cannot be proxied through Vercel — socket.io must use your API origin
# Example: https://finsocial-core-api-latest.onrender.com
VITE_BACKEND_URL=
