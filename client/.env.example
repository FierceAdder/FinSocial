VITE_SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/0
# Dev proxy target (restart Vite after changing)
# Express: http://localhost:5050 (use 5050 on macOS — AirPlay often occupies :5000)
# Docker nginx: http://localhost:9999
VITE_DEV_BACKEND=http://localhost:5050
# Optional: bypass Vite proxy (must match core-api CORS_ORIGIN)
# VITE_API_BASE=http://localhost:5050/api
# Production (e.g. Vercel): WebSockets cannot be proxied through Vercel — socket.io must use your API origin
# Example: https://finsocial-core-api-latest.onrender.com
VITE_BACKEND_URL=
